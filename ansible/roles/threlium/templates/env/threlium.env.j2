# Managed by Ansible — единый env-файл Threlium (systemd EnvironmentFile=).
# Приоритет: эти переменные перекрывают config/threlium.yaml и defaults в коде.
# Формат вложенности в env: THRELIUM_<СЕКЦИЯ>__<ПОЛЕ> (двойное подчёркивание).
# Источник правды по допустимым значениям и валидации: threlium/settings.py (Field + validators).
#
# Списки llm_endpoints / embedding_endpoints / bridges и другие структурные секции
# задаются в config/threlium.yaml (из Ansible dict-переменных threlium_litellm,
# threlium_bridges и т.д.). Здесь только bootstrap-пути, глобальные ключи
# провайдеров и скалярные env-override, которые удобно менять без re-deploy.

# --- Bootstrap: пути и PATH для user-юнитов ---
THRELIUM_HOME={{ threlium_home }}
THRELIUM_REPO={{ threlium_repo_path }}
THRELIUM_VENV={{ threlium_repo_path }}/.venv
PATH={{ threlium_repo_path }}/.venv/bin:{{ ansible_facts['env'].PATH | default('/usr/local/bin:/usr/bin:/bin') }}
# THRELIUM_LOG_LEVEL=DEBUG   # пример: DEBUG, INFO, WARNING, ERROR

# --- LiteLLM: глобальные ретраи SDK (≥0) ---
THRELIUM_LITELLM__MAX_RETRIES={{ threlium_litellm_effective.max_retries | default(3) }}

# --- Enrich ---
THRELIUM_ENRICH__CONTEXT_MAX_CHARS={{ threlium_enrich_effective.context_max_chars | default(180000) }}

# --- Knowledge ---
THRELIUM_KNOWLEDGE__LOGIC_REPORT_MAX_CHARS={{ threlium_knowledge_effective.logic_report_max_chars | default(4000) }}
THRELIUM_KNOWLEDGE__OBSERVATION_MAX_CHARS={{ threlium_knowledge_effective.observation_max_chars | default(180000) }}

# --- LightRAG ---
THRELIUM_LIGHTRAG__LANGUAGE={{ threlium_lightrag_effective.language | default('Russian') }}
THRELIUM_LIGHTRAG__ENTITY_TYPES={{ threlium_lightrag_effective.entity_types | default('person,organization,location,concept,event,technology,document') }}
THRELIUM_LIGHTRAG__CHUNK_BODY_TOKENS={{ threlium_lightrag_effective.chunk_body_tokens | default(1200) }}
THRELIUM_LIGHTRAG__CHUNK_BODY_OVERLAP_PCT={{ threlium_lightrag_effective.chunk_body_overlap_pct | default(10) }}
THRELIUM_LIGHTRAG__INSERT_BATCH={{ threlium_lightrag_effective.insert_batch | default(16) }}
THRELIUM_LIGHTRAG__PROMPTS_OVERLAY={{ threlium_lightrag_effective.prompts_overlay | default(true) | lower }}
{% if threlium_lightrag_effective.aquery_hints | default('') | trim | length > 0 %}
THRELIUM_LIGHTRAG__AQUERY_HINTS={{ threlium_lightrag_effective.aquery_hints | trim }}
{% endif %}

# --- Bridges: Email (IMAP) ---
{% if threlium_bridges.email.imap_host | default('') | trim | length > 0 %}
THRELIUM_BRIDGES__EMAIL__IMAP_HOST={{ threlium_bridges.email.imap_host }}
THRELIUM_BRIDGES__EMAIL__IMAP_USER={{ threlium_bridges.email.imap_user }}
THRELIUM_BRIDGES__EMAIL__IMAP_PASS={{ threlium_bridges.email.imap_pass }}
THRELIUM_BRIDGES__EMAIL__IMAP_PORT={{ threlium_bridges.email.imap_port | default(0) }}
THRELIUM_BRIDGES__EMAIL__IMAP_USE_SSL={{ threlium_bridges.email.imap_use_ssl | default(true) | lower }}
THRELIUM_BRIDGES__EMAIL__IMAP_SSL_VERIFY={{ threlium_bridges.email.imap_ssl_verify | default(true) | lower }}
THRELIUM_BRIDGES__EMAIL__IMAP_IDLE_MAX_SEC={{ threlium_bridges.email.imap_idle_max_sec | default(1740) }}
THRELIUM_BRIDGES__EMAIL__IMAP_PROCESSED_FOLDER={{ threlium_bridges.email.imap_processed_folder | default('') }}
THRELIUM_BRIDGES__EMAIL__IMAP_ENSURE_PROCESSED_FOLDER={{ threlium_bridges.email.imap_ensure_processed_folder | default(true) | lower }}
{% endif %}

# --- Bridges: Matrix ---
{% if threlium_bridge_matrix_enabled | default(false) | bool %}
THRELIUM_BRIDGES__MATRIX__HOMESERVER={{ threlium_bridges.matrix.homeserver }}
THRELIUM_BRIDGES__MATRIX__USER={{ threlium_bridges.matrix.user }}
THRELIUM_BRIDGES__MATRIX__TOKEN={{ threlium_bridges.matrix.token }}
{% endif %}

# --- Bridges: Telegram ---
{% if threlium_bridge_telegram_enabled | default(false) | bool %}
THRELIUM_BRIDGES__TELEGRAM__BOT_TOKEN={{ threlium_bridges.telegram.bot_token }}
{% if threlium_bridges.telegram.bot_api_base | default('') | trim | length > 0 %}
THRELIUM_BRIDGES__TELEGRAM__BOT_API_BASE={{ threlium_bridges.telegram.bot_api_base | trim }}
{% endif %}
{% endif %}

# --- Egress ---
{% if threlium_egress.email_from | default('') | trim | length > 0 %}
THRELIUM_EGRESS__EMAIL_FROM={{ threlium_egress.email_from | trim }}
{% endif %}

# --- E2e ---
{% if (threlium_e2e | default({})).litellm_route_correlation | default(false) | bool %}
THRELIUM_E2E__LITELLM_ROUTE_CORRELATION=true
{% endif %}
