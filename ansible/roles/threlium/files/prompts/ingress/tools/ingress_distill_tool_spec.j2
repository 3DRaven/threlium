{#- tool_spec for ingress distill (tool_choice=required, score 1) -#}
{
  "type": "function",
  "function": {
    "name": "ingress_distill",
    "description": "Normalize one incoming user turn into structured fields for the agent pipeline.",
    "parameters": {
      "type": "object",
      "properties": {
        "user_intent": {
          "type": "string",
          "maxLength": {{ distill_max_chars }},
          "description": "Always English: operational brief of NEW user content only (no quoted prior thread). Paraphrase; do not paste long untranslated quotes."
        },
        "user_reply_language": {
          "type": "string",
          "maxLength": 64,
          "description": "Language for eventual user-facing replies only (e.g. English, German), not the language of user_intent."
        },
        "open_gaps": {
          "type": "array",
          "items": { "type": "string", "maxLength": 300 },
          "maxItems": 3,
          "description": "English only. Blocking unknowns for internal agent from NEW prose only; empty array if none."
        },
        "step_back_notes": {
          "type": "array",
          "items": { "type": "string", "maxLength": 300 },
          "maxItems": 5,
          "description": "English only. Implicit goals/constraints from NEW user prose only (not quoted thread)."
        }
      },
      "required": ["user_intent", "user_reply_language"],
      "additionalProperties": false
    }
  }
}
