{#- tool_spec for enrich late hypotheses (tool_choice=required, score 1) — standalone -#}
{
  "type": "function",
  "function": {
    "name": "enrich_task_hypotheses",
    "description": "Tool-only: call once; no assistant text outside tool_calls. After full context retrieval (graph + thread + memory), add ONLY new, falsifiable verification subtasks that the existing ledger does not already cover. Return an empty array when the retrieved context raises no new thing worth verifying.",
    "parameters": {
      "type": "object",
      "properties": {
        "subtasks": {
          "type": "array",
          "description": "Verification subtask texts, English; each is one checkable claim to confirm or refute against the project/graph. Do not restate existing ledger subtasks; add only genuinely new ones.",
          "items": { "type": "string", "minLength": 1, "maxLength": 400 },
          "maxItems": 8
        }
      },
      "required": ["subtasks"],
      "additionalProperties": false
    }
  }
}
