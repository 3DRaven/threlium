{#- LLM-facing text is English-only: Cyrillic uses roughly 2–3× more tokens per word.
    This Jinja comment is stripped and never sent to the model.
    docs/MEMORY_TABLE.md §1: tool-spec for route `thread_memory`. -#}
{
  "type": "function",
  "function": {
    "name": "thread_memory",
    "description": "Tool-only: call once; no assistant text outside tool_calls. Maze move — ANCHOR a fact on the map for this thread only. Store a note for the CURRENT dialog thread. The note is written into the unified knowledge/memory graph — the SAME graph as domain documentation and past conversations — as entities/relations retrievable later via memory_query (and surfaced in <thread_memory>). Use for facts or decisions needed on later turns in this thread; not for global agent or world facts (use global_memory for those). A good trigger is persisting a correction or a relationship you discovered while investigating, so the graph stops being wrong. After discovery: record canonical file paths and reuse decisions (e.g. 'Email handling lives in bridges/email.py; extend it rather than adding a parallel module'). When NOT to use: do not persist transient reasoning scratch you will not need again, and do not store cross-thread facts here — that is global_memory. Boundary: thread_memory = scoped to this conversation; global_memory = relevant to all future threads.",
    "parameters": {
      "type": "object",
      "properties": {
        "reasoning": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500,
          "description": "Brief explanation of why this fact is worth persisting in thread memory."
        },
        "note": {
          "type": "string",
          "minLength": 1,
          "maxLength": 8000,
          "description": "Thread note text (UTF-8). Third person, no I/we pronouns — self-contained for LightRAG."
        }
      },
      "required": ["reasoning", "note"],
      "additionalProperties": false
    }
  }
}
