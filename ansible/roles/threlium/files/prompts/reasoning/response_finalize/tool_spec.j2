{#- LLM-facing text is English-only: Cyrillic uses roughly 2–3× more tokens per word.
    This Jinja comment is stripped and never sent to the model.
    tool-spec for route `response_finalize`. -#}
{
  "type": "function",
  "function": {
    "name": "response_finalize",
    "description": "Send final reply. Short answer: full text in content. Built via response_append: omit content or add closing fragment. For long responses built with response_append, prefer using response_observe first to verify completeness. subject required. Match user language; factual; Markdown when helpful; never fabricate. When NOT to use: not for a partial draft with sub-questions still open or a buffer not yet verified — keep appending / observe first; not while the hop budget still permits resolving an unverified assumption.",
    "parameters": {
      "type": "object",
      "properties": {
        "reasoning": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500,
          "description": "Brief explanation of why you are finalizing now and what you verified before this decision."
        },
        "subject": {
          "type": "string",
          "minLength": 1,
          "description": "Reply subject (short, no line breaks)."
        },
        "content": {
          "type": ["string", "null"],
          "default": null,
          "description": "Optional final fragment or full text for quick replies. null if accumulated via response_append."
        },
        "verification_summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500,
          "description": "What you verified before finalizing. For buffered responses: sections present, coherence, factual accuracy checks. For direct replies: briefly state why content is correct and complete. In both cases, list which sub-questions were resolved and any discovered issues surfaced or addressed (or state none were found)."
        }
      },
      "required": ["reasoning", "subject", "verification_summary"],
      "additionalProperties": false
    }
  }
}
