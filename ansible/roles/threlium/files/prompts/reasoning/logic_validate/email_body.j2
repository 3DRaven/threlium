    logic_validate body: canonical JSON for knowledge_fsm.parse_logic_validate_payload. -#}
{%- set _payload = {'reasoning': reasoning, 'shapes_ttl': shapes_ttl, 'facts_ttl': facts_ttl} -%}
{%- if ontology_ttl is defined and ontology_ttl -%}
{%-   set _ = _payload.update({'ontology_ttl': ontology_ttl}) -%}
{%- endif -%}
{%- if inference is defined and inference -%}
{%-   set _ = _payload.update({'inference': inference}) -%}
{%- endif -%}
{{ _payload | tojson }}
