{#- LLM-facing text is English-only: Cyrillic uses roughly 2–3× more tokens per word.
    This Jinja comment is stripped and never sent to the model.
    docs/ARCHITECTURE.md §6.1: reasoning user message.
    Each context source is in a separate XML section for clear LLM prioritization.
    Variables are extracted from enriched multipart MIME parts by Content-ID
    (EnrichPartId) in reasoning.py _build_prompt(). -#}
<envelope>
Message-ID: {{ message_id or "(none)" }}
In-Reply-To: {{ in_reply_to or "(none)" }}
References: {{ references or "(none)" }}
Subject: {{ subject or "(none)" }}
From: {{ from_hdr or "(none)" }}
</envelope>
{% if user_text %}

<user_message>
{{ user_text }}
</user_message>
{% endif %}
{% if knowledge_graph %}

<knowledge_graph source="lightrag-graph-sample">
{{ knowledge_graph }}
</knowledge_graph>
{% endif %}
{% if mail_context %}

<conversation_history>
{{ mail_context }}
</conversation_history>
{% endif %}
{% if thread_memory %}

<thread_memory>
{{ thread_memory }}
</thread_memory>
{% endif %}
{% if global_memory %}

<global_memory>
{{ global_memory }}
</global_memory>
{% endif %}
{% if response_state %}

<response_buffer_state>
{{ response_state }}
</response_buffer_state>
{% endif %}
{% if task_state %}

<task_state>
{{ task_state }}
</task_state>
{% endif %}
{% if history %}

{#- Chronological stream of accumulated step results since the last reasoning turn
    (the fast-cycle delta). Each entry is annotated with its origin stage; the tool
    spec describes the semantics of every stage, so no per-kind XML tags are needed. -#}
<conversation_delta>
{% for entry in history %}[from: {{ entry.origin }}]
{{ entry.text }}{% if not loop.last %}

---

{% endif %}{% endfor %}
</conversation_delta>
{% endif %}
