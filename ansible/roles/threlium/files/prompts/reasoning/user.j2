{#- LLM-facing text is English-only: Cyrillic uses roughly 2–3× more tokens per word.
    This Jinja comment is stripped and never sent to the model.
    docs/ARCHITECTURE.md §6.1: reasoning user message.
    Each context source is in a separate XML section for clear LLM prioritization.
    Variables are extracted from enriched multipart MIME parts by Content-ID
    (EnrichPartId) in reasoning.py _build_prompt(). -#}
<envelope>
Message-ID: {{ message_id or "(none)" }}
In-Reply-To: {{ in_reply_to or "(none)" }}
References: {{ references or "(none)" }}
Subject: {{ subject or "(none)" }}
From: {{ from_hdr or "(none)" }}
</envelope>
{% if user_text %}

<user_message>
{{ user_text }}
</user_message>
{% endif %}
{% if knowledge_graph %}

<knowledge_graph source="lightrag-graph-sample">
{{ knowledge_graph }}
</knowledge_graph>
{% endif %}
{% if mail_context %}

<conversation_history>
{{ mail_context }}
</conversation_history>
{% endif %}
{% if unified_deltas %}

<conversation_delta>
{% for block in unified_deltas %}{{ block }}{% if not loop.last %}

---

{% endif %}{% endfor %}
</conversation_delta>
{% endif %}
{% if thread_memory %}

<thread_memory>
{{ thread_memory }}
</thread_memory>
{% endif %}
{% if global_memory %}

<global_memory>
{{ global_memory }}
</global_memory>
{% endif %}
{% if response_state %}

<response_buffer_state>
{{ response_state }}
</response_buffer_state>
{% endif %}
{% if task_state %}

<task_state>
{{ task_state }}
</task_state>
{% endif %}
{% if response_observations %}

<response_observation>
{% for note in response_observations %}{{ note }}{% if not loop.last %}

---

{% endif %}{% endfor %}
</response_observation>
{% endif %}
{% if memory_notes %}

<memory_note>
{% for note in memory_notes %}{{ note }}{% if not loop.last %}

---

{% endif %}{% endfor %}
</memory_note>
{% endif %}
{% if observation_notes %}

<observation>
{% for note in observation_notes %}{{ note }}{% if not loop.last %}

---

{% endif %}{% endfor %}
</observation>
{% endif %}
