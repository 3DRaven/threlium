{
  "request": {
    "method": "POST",
    "urlPathPattern": "^(/v1/chat/completions|/chat/completions)$",
    "headers": {
      "X-Threlium-Call-Site": {
        "equalTo": "reasoning"
      }
    },
    "bodyPatterns": [
      {
        "matches": "(?s).*(openai/threlium_e2e_l0|threlium_e2e_l0).*"
      },
      {
        "contains": "<envelope>"
      },
      {
        "contains": "\"tools\""
      },
      {
        "contains": "PARSE ERROR"
      },
      {
        "contains": "Gate retry counter:"
      },
      {
        "comment": "Только wrong_tool retry (retry_count>0), не первый gated hop — см. formal_reason_gate.j2.",
        "contains": "disallowed tool"
      },
      {
        "contains": "E2E-FORMAL-REASON-GATE-MATRIX-BODY"
      }
    ],
    "customMatcher": {
      "name": "state-matcher",
      "parameters": {
        "hasContext": "stub-formal-reason-gate-matrix-01::{{request.headers.[X-Threlium-Thread-Root]}}",
        "hasProperty": "phase_matrix_fatal_done",
        "hasNotProperty": "phase_matrix_mq_done"
      }
    }
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": {
      "id": "chatcmpl-e2e-formal-reason-matrix-reasoning-2-retry",
      "object": "chat.completion",
      "created": 0,
      "model": "gpt-4o-mini",
      "choices": [
        {
          "index": 0,
          "finish_reason": "tool_calls",
          "message": {
            "role": "assistant",
            "content": null,
            "tool_calls": [
              {
                "id": "call_e2e_memory_query_matrix_gate_retry",
                "type": "function",
                "function": {
                  "name": "memory_query",
                  "arguments": "{\"reasoning\": \"e2e matrix: memory_query allowed under formal_reason gate after parse fatal\", \"query\": \"turtle_syntax.md SHACL gate recovery\"}"
                }
              }
            ]
          }
        }
      ]
    }
  },
  "serveEventListeners": [
    {
      "name": "recordState",
      "parameters": {
        "context": "{{request.headers.[X-Threlium-Thread-Root]}}",
        "list": {
          "addLast": {
            "cs": "{{request.headers.[X-Threlium-Call-Site]}}"
          }
        }
      }
    }
  ]
}
