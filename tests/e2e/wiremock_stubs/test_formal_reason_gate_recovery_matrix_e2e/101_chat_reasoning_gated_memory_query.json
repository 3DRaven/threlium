{
  "request": {
    "method": "POST",
    "urlPathPattern": "^(/v1/chat/completions|/chat/completions)$",
    "headers": {
      "X-Threlium-Call-Site": {
        "equalTo": "fsm"
      }
    },
    "bodyPatterns": [
      {
        "matches": "(?s).*(openai/threlium_e2e_l0|threlium_e2e_l0).*"
      },
      {
        "contains": "<envelope>"
      },
      {
        "contains": "\"tools\""
      },
      {
        "contains": "PARSE ERROR"
      },
      {
        "contains": "FORMAL REASON GATE"
      },
      {
        "contains": "E2E-FORMAL-REASON-GATE-MATRIX-BODY"
      },
      {
        "doesNotMatch": "(?s).*\"enable_thinking\"\\s*:\\s*false.*"
      }
    ],
    "customMatcher": {
      "name": "state-matcher",
      "parameters": {
        "hasContext": "stub-formal-reason-gate-matrix-01::{{request.headers.[x-threlium-thread-root]}}",
        "hasProperty": "phase_matrix_fatal_done",
        "hasNotProperty": "phase_matrix_mq_done"
      }
    }
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": {
      "id": "chatcmpl-e2e-formal-reason-matrix-reasoning-2",
      "object": "chat.completion",
      "created": 0,
      "model": "gpt-4o-mini",
      "choices": [
        {
          "index": 0,
          "finish_reason": "tool_calls",
          "message": {
            "role": "assistant",
            "content": null,
            "tool_calls": [
              {
                "id": "call_e2e_memory_query_matrix_gate",
                "type": "function",
                "function": {
                  "name": "memory_query",
                  "arguments": "{\"reasoning\": \"e2e matrix: memory_query allowed under formal_reason gate after parse fatal\", \"query\": \"turtle_syntax.md SHACL gate recovery\"}"
                }
              }
            ]
          }
        }
      ]
    }
  },
  "serveEventListeners": [
    {
      "name": "recordState",
      "parameters": {
        "context": "stub-formal-reason-gate-matrix-01::{{request.headers.[x-threlium-thread-root]}}",
        "state": {
          "phase_matrix_mq_done": "1"
        }
      }
    }
  ]
}
