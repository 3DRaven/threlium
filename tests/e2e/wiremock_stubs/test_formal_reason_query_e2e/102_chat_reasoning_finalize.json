{
  "request": {
    "method": "POST",
    "urlPathPattern": "^(/v1/chat/completions|/chat/completions)$",
    "headers": {
      "X-Threlium-Call-Site": {
        "equalTo": "reasoning"
      }
    },
    "bodyPatterns": [
      {
        "matches": "(?s).*(openai/threlium_e2e_l0|threlium_e2e_l0).*"
      },
      {
        "contains": "<envelope>"
      },
      {
        "contains": "\"tools\""
      },
      {
        "contains": "conforms: True"
      },
      {
        "contains": "query_result"
      },
      {
        "contains": "name=Alice"
      }
    ],
    "customMatcher": {
      "name": "state-matcher",
      "parameters": {
        "hasContext": "stub-formal-reason-query-01::{{request.headers.[X-Threlium-Thread-Root]}}",
        "hasProperty": "phase_formal_reason_done_ledger_done"
      }
    }
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": {
      "id": "chatcmpl-e2e-formal-reason-query-reasoning-finalize",
      "object": "chat.completion",
      "created": 0,
      "model": "gpt-4o-mini",
      "choices": [
        {
          "index": 0,
          "finish_reason": "tool_calls",
          "message": {
            "role": "assistant",
            "content": null,
            "tool_calls": [
              {
                "id": "call_e2e_response_finalize_query",
                "type": "function",
                "function": {
                  "name": "response_finalize",
                  "arguments": "{\"reasoning\": \"e2e: finalizing after formal_reason SPARQL query\", \"subject\": \"Re: e2e reply\", \"verification_summary\": \"e2e: formal_reason returned query_result bindings for ex:name\", \"content\": \"e2e-formal-reason-query-verified-answer\"}"
                }
              }
            ]
          }
        }
      ]
    }
  },
  "serveEventListeners": [
    {
      "name": "recordState",
      "parameters": {
        "context": "{{request.headers.[X-Threlium-Thread-Root]}}",
        "list": {
          "addLast": {
            "cs": "{{request.headers.[X-Threlium-Call-Site]}}"
          }
        }
      }
    }
  ]
}
