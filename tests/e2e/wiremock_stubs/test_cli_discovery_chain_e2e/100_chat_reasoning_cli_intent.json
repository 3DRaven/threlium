{
  "request": {
    "method": "POST",
    "urlPathPattern": "^(/v1/chat/completions|/chat/completions)$",
    "headers": {
      "X-Threlium-Call-Site": {
        "equalTo": "reasoning"
      }
    },
    "bodyPatterns": [
      {
        "matches": "(?s).*(openai/threlium_e2e_l0|threlium_e2e_l0).*"
      },
      {
        "contains": "<envelope>"
      },
      {
        "contains": "\"tools\""
      },
      {
        "contains": "E2E-CLI-DISCOVERY-CHAIN-BODY"
      }
    ],
    "customMatcher": {
      "name": "state-matcher",
      "parameters": {
        "hasContext": "stub-cli-discovery-chain-01::{{request.headers.[X-Threlium-Thread-Root]}}",
        "hasProperty": "active",
        "hasNotProperty": "phase_cli_intent_done"
      }
    }
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "transformers": [
      "response-template"
    ],
    "jsonBody": {
      "id": "chatcmpl-e2e-live-cli-intent-allow",
      "object": "chat.completion",
      "created": 0,
      "model": "gpt-4o-mini",
      "choices": [
        {
          "index": 0,
          "finish_reason": "tool_calls",
          "message": {
            "role": "assistant",
            "content": null,
            "tool_calls": [
              {
                "id": "call_threlium_e2e_cli_intent_allow",
                "type": "function",
                "function": {
                  "name": "cli_intent",
                  "arguments": "{\"argv\": [\"bash\", \"-c\", \"rg -l E2E-CLI-DISCOVERY-MARKER /home/threlium/threlium/agent/e2e-cli-discovery-marker.txt | grep -E 'DISCOVERY|MARKER' | head -n 5; echo E2E-CLI-DISCOVERY-STDOUT-MARKER\"], \"reasoning\": \"e2e discovery chain: rg | grep -E with pipe in quotes (th-agent regression)\"}"
                }
              }
            ]
          }
        }
      ]
    }
  },
  "serveEventListeners": [
    {
      "name": "recordState",
      "parameters": {
        "context": "stub-cli-discovery-chain-01::{{request.headers.[X-Threlium-Thread-Root]}}",
        "state": {
          "phase_cli_intent_done": "1"
        }
      }
    },
    {
      "name": "recordState",
      "parameters": {
        "context": "{{request.headers.[X-Threlium-Thread-Root]}}",
        "list": {
          "addLast": {
            "cs": "{{request.headers.[X-Threlium-Call-Site]}}"
          }
        }
      }
    }
  ]
}
