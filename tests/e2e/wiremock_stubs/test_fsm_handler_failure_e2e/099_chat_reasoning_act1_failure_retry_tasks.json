{
  "request": {
    "method": "POST",
    "urlPathPattern": "^(/v1/chat/completions|/chat/completions)$",
    "headers": {
      "X-Threlium-Call-Site": {
        "equalTo": "fsm"
      }
    },
    "bodyPatterns": [
      {
        "matches": "(?s).*(openai/threlium_e2e_l0|threlium_e2e_l0).*"
      },
      {
        "contains": "<envelope>"
      },
      {
        "contains": "\"tools\""
      },
      {
        "contains": "E2E-FSM-HANDLER-FAILURE-BODY"
      }
    ],
    "customMatcher": {
      "name": "state-matcher",
      "parameters": {
        "hasContext": "stub-fsm-handler-failure-01::{{request.headers.[x-threlium-thread-root]}}",
        "hasProperty": "phase_failure_seen",
        "hasNotProperty": "phase_failure_act1_retry_handled"
      }
    }
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": {
      "id": "chatcmpl-e2e-fsm-act1-failure-retry-tasks",
      "object": "chat.completion",
      "created": 0,
      "model": "gpt-4o-mini",
      "choices": [
        {
          "index": 0,
          "finish_reason": "tool_calls",
          "message": {
            "role": "assistant",
            "content": null,
            "tool_calls": [
              {
                "id": "call_e2e_fsm_act1_failure_retry_tasks",
                "type": "function",
                "function": {
                  "name": "tasks_upsert",
                  "arguments": "{\"reasoning\": \"e2e: close act1 ledger after forced 500\",\"new_subtasks\": [{\"text\": \"Acknowledge handler failure (act1)\",\"status\": \"done\"}]}"
                }
              }
            ]
          }
        }
      ]
    }
  },
  "serveEventListeners": [
    {
      "name": "recordState",
      "parameters": {
        "context": "stub-fsm-handler-failure-01::{{request.headers.[x-threlium-thread-root]}}",
        "state": {
          "phase_failure_act1_retry_handled": "1"
        }
      }
    }
  ]
}
