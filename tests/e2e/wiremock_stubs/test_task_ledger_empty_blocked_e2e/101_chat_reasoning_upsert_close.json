{
  "request": {
    "method": "POST",
    "urlPathPattern": "^(/v1/chat/completions|/chat/completions)$",
    "headers": {
      "X-Threlium-Call-Site": {
        "equalTo": "reasoning"
      }
    },
    "bodyPatterns": [
      {
        "matches": "(?s).*(openai/threlium_e2e_l0|threlium_e2e_l0).*"
      },
      {
        "contains": "<envelope>"
      },
      {
        "contains": "\"tools\""
      },
      {
        "comment": "After the empty-ledger block bounced to ingress, the LLM records work: one subtask marked done in the same tasks_upsert call (the trivial-answer path). content_id 262b71525451 = hash('Answer the user question about the task ledger').",
        "contains": "E2E-TASK-LEDGER-EMPTY-BODY"
      }
    ],
    "customMatcher": {
      "name": "state-matcher",
      "parameters": {
        "hasContext": "stub-task-ledger-empty-01::{{request.headers.[X-Threlium-Thread-Root]}}",
        "hasProperty": "phase_finalize_empty_blocked",
        "hasNotProperty": "phase_upsert_close_done"
      }
    }
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": {
      "id": "chatcmpl-e2e-task-ledger-empty-reasoning-2-upsert-close",
      "object": "chat.completion",
      "created": 0,
      "model": "gpt-4o-mini",
      "choices": [
        {
          "index": 0,
          "finish_reason": "tool_calls",
          "message": {
            "role": "assistant",
            "content": null,
            "tool_calls": [
              {
                "id": "call_e2e_empty_upsert_close",
                "type": "function",
                "function": {
                  "name": "tasks_upsert",
                  "arguments": "{\"reasoning\": \"e2e: trivial answer, record one subtask as done\", \"new_subtasks\": [{\"text\": \"Answer the user question about the task ledger\", \"status\": \"done\"}], \"subtask_updates\": [{\"content_id\": \"481a8275734a\", \"status\": \"done\"}]}"
                }
              }
            ]
          }
        }
      ]
    }
  },
  "serveEventListeners": [
    {
      "name": "recordState",
      "parameters": {
        "context": "stub-task-ledger-empty-01::{{request.headers.[X-Threlium-Thread-Root]}}",
        "state": {
          "phase_upsert_close_done": "1"
        }
      }
    },
    {
      "name": "recordState",
      "parameters": {
        "context": "{{request.headers.[X-Threlium-Thread-Root]}}",
        "list": {
          "addLast": {
            "cs": "{{request.headers.[X-Threlium-Call-Site]}}"
          }
        }
      }
    }
  ]
}
