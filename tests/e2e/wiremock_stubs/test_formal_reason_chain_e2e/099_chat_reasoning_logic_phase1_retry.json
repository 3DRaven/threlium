{
  "request": {
    "method": "POST",
    "urlPathPattern": "^(/v1/chat/completions|/chat/completions)$",
    "headers": {
      "X-Threlium-Call-Site": {
        "equalTo": "reasoning"
      }
    },
    "bodyPatterns": [
      {
        "matches": "(?s).*(openai/threlium_e2e_l0|threlium_e2e_l0).*"
      },
      {
        "contains": "<envelope>"
      },
      {
        "contains": "\"tools\""
      },
      {
        "contains": "E2E-FORMAL-REASON-CHAIN-BODY"
      },
      {
        "comment": "Повторные completion в том же _decide после recordState phase_formal_reason_done у 100_: тело без conforms, фаза уже выставлена.",
        "doesNotContain": "conforms: True"
      },
      {
        "comment": "2-й reasoning (memory_query): unified-delta уже несёт ex:PositiveAgeShape — отдаём 101_, не retry formal_reason.",
        "doesNotContain": "ex:PositiveAgeShape"
      }
    ],
    "customMatcher": {
      "name": "state-matcher",
      "parameters": {
        "hasContext": "stub-formal-reason-chain-01::{{request.headers.[X-Threlium-Thread-Root]}}",
        "hasProperty": "phase_formal_reason_done",
        "hasNotProperty": "phase_query_done"
      }
    }
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "transformers": [
      "response-template"
    ],
    "jsonBody": {
      "id": "chatcmpl-e2e-formal-reason-reasoning-1-retry",
      "object": "chat.completion",
      "created": 0,
      "model": "gpt-4o-mini",
      "choices": [
        {
          "index": 0,
          "finish_reason": "tool_calls",
          "message": {
            "role": "assistant",
            "content": null,
            "tool_calls": [
              {
                "id": "call_e2e_formal_reason_1",
                "type": "function",
                "function": {
                  "name": "formal_reason",
                  "arguments": "{\"reasoning\": \"e2e: verifying temporal ordering invariant with SHACL-SPARQL; target shape ex:PositiveAgeShape\", \"shapes_ttl\": \"@prefix sh: <http://www.w3.org/ns/shacl#> .\\n@prefix ex: <http://example.org/> .\\n\\nex:PositiveAgeShape a sh:NodeShape ;\\n  sh:targetClass ex:Person ;\\n  sh:property [\\n    sh:path ex:age ;\\n    sh:minInclusive 0 ;\\n    sh:message \\\"Age must be non-negative\\\" ;\\n  ] .\", \"facts_ttl\": \"@prefix ex: <http://example.org/> .\\n\\nex:alice a ex:Person ;\\n  ex:age 30 .\\n\\nex:bob a ex:Person ;\\n  ex:age 25 .\"}"
                }
              }
            ]
          }
        }
      ]
    }
  },
  "serveEventListeners": [
    {
      "name": "recordState",
      "parameters": {
        "context": "{{request.headers.[X-Threlium-Thread-Root]}}",
        "list": {
          "addLast": {
            "cs": "{{request.headers.[X-Threlium-Call-Site]}}"
          }
        }
      }
    }
  ]
}
