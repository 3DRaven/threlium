{
  "request": {
    "method": "POST",
    "urlPathPattern": "^(/v1/chat/completions|/chat/completions)$",
    "headers": {
      "X-Threlium-Call-Site": {
        "equalTo": "reasoning"
      }
    },
    "bodyPatterns": [
      {
        "matches": "(?s).*(openai/threlium_e2e_l0|threlium_e2e_l0).*"
      },
      {
        "contains": "<envelope>"
      },
      {
        "contains": "\"tools\""
      },
      {
        "contains": "conforms: True"
      },
      {
        "comment": "unified-delta: вход reasoning -> formal_reason (полный shapes_ttl) попадает в промпт 2-го reasoning через <conversation_delta>. Маркер ex:PositiveAgeShape есть только во входе стадии, не в observation-note (та опускает shapes/facts_ttl).",
        "contains": "ex:PositiveAgeShape"
      }
    ],
    "customMatcher": {
      "name": "state-matcher",
      "parameters": {
        "hasContext": "stub-formal-reason-chain-01::{{request.headers.[X-Threlium-Thread-Root]}}",
        "hasProperty": "phase_formal_reason_done",
        "hasNotProperty": "phase_query_done"
      }
    }
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "transformers": [
      "response-template"
    ],
    "jsonBody": {
      "id": "chatcmpl-e2e-formal-reason-reasoning-2",
      "object": "chat.completion",
      "created": 0,
      "model": "gpt-4o-mini",
      "choices": [
        {
          "index": 0,
          "finish_reason": "tool_calls",
          "message": {
            "role": "assistant",
            "content": null,
            "tool_calls": [
              {
                "id": "call_e2e_memory_query_1",
                "type": "function",
                "function": {
                  "name": "memory_query",
                  "arguments": "{\"reasoning\": \"e2e: querying knowledge base for SHACL-SPARQL reference after successful validation\", \"query\": \"SHACL sh:sparql constraint SELECT variable binding\"}"
                }
              }
            ]
          }
        }
      ]
    }
  },
  "serveEventListeners": [
    {
      "name": "recordState",
      "parameters": {
        "context": "stub-formal-reason-chain-01::{{request.headers.[X-Threlium-Thread-Root]}}",
        "state": {
          "phase_query_done": "1"
        }
      }
    },
    {
      "name": "recordState",
      "parameters": {
        "context": "{{request.headers.[X-Threlium-Thread-Root]}}",
        "list": {
          "addLast": {
            "cs": "{{request.headers.[X-Threlium-Call-Site]}}"
          }
        }
      }
    }
  ]
}
