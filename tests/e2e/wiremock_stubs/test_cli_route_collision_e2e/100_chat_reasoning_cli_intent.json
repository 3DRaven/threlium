{
  "request": {
    "method": "POST",
    "urlPathPattern": "^(/v1/chat/completions|/chat/completions)$",
    "headers": {
      "X-Threlium-Call-Site": {
        "equalTo": "fsm"
      }
    },
    "bodyPatterns": [
      {
        "matches": "(?s).*(openai/threlium_e2e_l0|threlium_e2e_l0).*"
      },
      {
        "contains": "<envelope>"
      },
      {
        "contains": "\"tools\""
      },
      {
        "contains": "E2E-CLI-ROUTE-COLLISION-BODY"
      }
    ],
    "customMatcher": {
      "name": "state-matcher",
      "parameters": {
        "hasContext": "stub-cli-route-collision-01::{{request.headers.[x-threlium-thread-root]}}",
        "hasProperty": "active",
        "hasNotProperty": "phase_cli_intent_done"
      }
    }
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": {
      "id": "chatcmpl-e2e-cli-route-collision",
      "object": "chat.completion",
      "created": 0,
      "model": "gpt-4o-mini",
      "choices": [
        {
          "index": 0,
          "finish_reason": "tool_calls",
          "message": {
            "role": "assistant",
            "content": null,
            "tool_calls": [
              {
                "id": "call_threlium_e2e_cli_route_collision",
                "type": "function",
                "function": {
                  "name": "cli_intent",
                  "arguments": "{\"argv\": [\"memory_query\"], \"reasoning\": \"e2e route collision: argv[0] names FSM route memory_query instead of OS binary\"}"
                }
              }
            ]
          }
        }
      ]
    }
  },
  "serveEventListeners": [
    {
      "name": "recordState",
      "parameters": {
        "context": "stub-cli-route-collision-01::{{request.headers.[x-threlium-thread-root]}}",
        "state": {
          "phase_cli_intent_done": "1"
        }
      }
    }
  ]
}
