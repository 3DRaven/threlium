{
  "priority": 1,
  "request": {
    "method": "POST",
    "urlPathPattern": "^(/v1/chat/completions|/chat/completions)$",
    "headers": {
      "X-Threlium-Call-Site": {
        "equalTo": "fsm"
      }
    },
    "bodyPatterns": [
      {
        "matches": "(?s).*(openai/threlium_e2e_l0|threlium_e2e_l0).*"
      },
      {
        "contains": "<envelope>"
      },
      {
        "contains": "\"tools\""
      },
      {
        "contains": "E2E-REASONING-LITELLM-BODY-MARKER"
      },
      {
        "doesNotMatch": "(?s).*finish_reason=length.*"
      },
      {
        "doesNotMatch": "(?s).*\"enable_thinking\"\\s*:\\s*false.*"
      }
    ],
    "customMatcher": {
      "name": "state-matcher",
      "parameters": {
        "hasContext": "stub-reasoning-litellm-live-01::{{request.headers.[x-threlium-thread-root]}}",
        "hasNotProperty": "phase_tasks_ledger_done"
      }
    }
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": {
      "id": "chatcmpl-e2e-length-truncated",
      "object": "chat.completion",
      "created": 0,
      "model": "gpt-4o-mini",
      "choices": [
        {
          "index": 0,
          "finish_reason": "length",
          "message": {
            "role": "assistant",
            "content": "E2E-LENGTH-TRUNCATED-PARTIAL-OUTPUT",
            "tool_calls": null
          }
        }
      ]
    }
  }
}
