{
  "request": {
    "method": "POST",
    "urlPathPattern": "^(/v1/chat/completions|/chat/completions)$",
    "headers": {
      "X-Threlium-Call-Site": {
        "equalTo": "fsm"
      }
    },
    "bodyPatterns": [
      {
        "matches": "(?s).*(openai/threlium_e2e_l0|threlium_e2e_l0).*"
      },
      {
        "contains": "<envelope>"
      },
      {
        "contains": "\"tools\""
      }
    ],
    "customMatcher": {
      "name": "state-matcher",
      "parameters": {
        "hasContext": "stub-mailflow-live-hitl-mx-01::{{request.headers.[x-threlium-thread-root]}}",
        "hasProperty": "live_hitl_h02",
        "hasNotProperty": "live_hitl_h03"
      }
    }
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": {
      "id": "chatcmpl-e2e-hitl-cli-intent",
      "object": "chat.completion",
      "created": 0,
      "model": "gpt-4o-mini",
      "choices": [
        {
          "index": 0,
          "finish_reason": "tool_calls",
          "message": {
            "role": "assistant",
            "content": null,
            "tool_calls": [
              {
                "id": "call_hitl_cli_intent",
                "type": "function",
                "function": {
                  "name": "cli_intent",
                  "arguments": "{\"argv\": [\"id\"], \"privileged\": true, \"reasoning\": \"e2e SUBAGENT_TABLE+HITL: run id after user confirms CLI (mock).\"}"
                }
              }
            ]
          }
        }
      ]
    }
  },
  "serveEventListeners": [
    {
      "name": "recordState",
      "parameters": {
        "context": "stub-mailflow-live-hitl-mx-01::{{request.headers.[x-threlium-thread-root]}}",
        "state": {
          "live_hitl_h03": "1"
        }
      }
    }
  ]
}
