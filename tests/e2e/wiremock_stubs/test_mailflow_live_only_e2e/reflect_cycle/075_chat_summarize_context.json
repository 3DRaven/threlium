{
  "metadata": {
    "comment": [
      "summarize_thread_context (FSM enrich_fast/summarize стадия, НЕ lightrag summarize_descriptions из",
      "095): под -n2 нагрузкой контекст reflect-цикла маргинально переполняет бюджет и движок зовёт",
      "summarize_thread_context — на -n0 не срабатывает, поэтому стаба раньше не было → unmatched под",
      "-n2 → каскад по глобальному guard. Покрываем штатный overflow-путь. Изоляция по composite",
      "hasContext '<stub_tag>::<X-Threlium-Thread-Root>'."
    ]
  },
  "request": {
    "method": "POST",
    "urlPathPattern": "^(/v1/chat/completions|/chat/completions)$",
    "headers": {
      "X-Threlium-Call-Site": {
        "equalTo": "summarize_thread_context"
      }
    },
    "bodyPatterns": [
      {
        "contains": "\"tools\""
      }
    ],
    "customMatcher": {
      "name": "state-matcher",
      "parameters": {
        "hasContext": "stub-mailflow-live-reflect-cyc-01::{{request.headers.[X-Threlium-Thread-Root]}}"
      }
    }
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "transformers": [
      "response-template"
    ],
    "jsonBody": {
      "id": "chatcmpl-e2e-reflect-cyc-summarize-context",
      "object": "chat.completion",
      "created": 0,
      "model": "gpt-4o-mini",
      "choices": [
        {
          "index": 0,
          "finish_reason": "tool_calls",
          "message": {
            "role": "assistant",
            "content": null,
            "tool_calls": [
              {
                "id": "call_summarize_stub-mailflow-live-reflect-cyc-01",
                "type": "function",
                "function": {
                  "name": "summarize_thread_context",
                  "arguments": "{\"summary\": \"E2E reflect-cycle summarize context stub; preserve reflect-cyc-01 markers.\"}"
                }
              }
            ]
          }
        }
      ]
    }
  }
}
