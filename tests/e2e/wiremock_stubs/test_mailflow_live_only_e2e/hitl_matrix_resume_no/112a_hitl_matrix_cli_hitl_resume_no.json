{
  "request": {
    "method": "POST",
    "urlPathPattern": "^(/v1/chat/completions|/chat/completions)$",
    "headers": {
      "X-Threlium-Call-Site": {
        "equalTo": "confirm_cli_hitl"
      }
    },
    "bodyPatterns": [
      {
        "matches": "(?s).*(openai/threlium_e2e_l0|threlium_e2e_l0).*"
      },
      {
        "contains": "\"tools\""
      },
      {
        "contains": "confirm_cli_hitl"
      }
    ],
    "customMatcher": {
      "name": "state-matcher",
      "parameters": {
        "hasContext": "stub-mailflow-live-hitl-mx-no-01::{{request.headers.[X-Threlium-Thread-Root]}}",
        "hasProperty": "live_hitl_h03_open",
        "hasNotProperty": "live_hitl_h03_hitl_classified"
      }
    }
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": {
      "id": "chatcmpl-e2e-hitl-cli-hitl-resume-no",
      "object": "chat.completion",
      "created": 0,
      "model": "gpt-4o-mini",
      "choices": [
        {
          "index": 0,
          "finish_reason": "tool_calls",
          "message": {
            "role": "assistant",
            "content": null,
            "tool_calls": [
              {
                "id": "call_hitl_cli_hitl_resume_no",
                "type": "function",
                "function": {
                  "name": "confirm_cli_hitl",
                  "arguments": "{\"confirmed\": false, \"interpretation\": \"e2e: user declined privileged CLI.\"}"
                }
              }
            ]
          }
        }
      ]
    }
  },
  "serveEventListeners": [
    {
      "name": "recordState",
      "parameters": {
        "context": "stub-mailflow-live-hitl-mx-no-01::{{request.headers.[X-Threlium-Thread-Root]}}",
        "state": {
          "live_hitl_h03_hitl_classified": "1",
          "live_hitl_h03_reject": "1"
        }
      }
    },
    {
      "name": "recordState",
      "parameters": {
        "context": "{{request.headers.[X-Threlium-Thread-Root]}}",
        "list": {
          "addLast": {
            "cs": "{{request.headers.[X-Threlium-Call-Site]}}"
          }
        }
      }
    }
  ]
}
