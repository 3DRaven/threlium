{
  "request": {
    "method": "PUT",
    "urlPathPattern": "^/_matrix/client/(r0|v3)/rooms/[^/]+/send/m\\.room\\.message/[^/]+$",
    "customMatcher": {
      "name": "state-matcher",
      "parameters": {
        "hasContext": "stub-matrix-wiremock-live-e2e-01::{{request.headers.[X-Threlium-Thread-Root]}}"
      }
    }
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "transformers": [
      "response-template"
    ],
    "jsonBody": {
      "event_id": "$matrix_send_{{randomValue length=22 type='ALPHANUMERIC'}}"
    }
  },
  "serveEventListeners": [
    {
      "name": "recordState",
      "parameters": {
        "context": "{{request.headers.[X-Threlium-Thread-Root]}}",
        "state": {
          "saw_egress_edit": "{{#if (contains request.body 'ok matrix wiremock live e2e')}}1{{else}}{{state context=request.headers.[X-Threlium-Thread-Root] property='saw_egress_edit' default='0'}}{{/if}}"
        }
      }
    }
  ]
}
