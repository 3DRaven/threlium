{
  "request": {
    "method": "POST",
    "urlPathPattern": "^(/v1/embeddings|/embeddings)$",
    "bodyPatterns": [
      {
        "contains": "threlium_e2e_embed"
      },
      {
        "matches": "(?s).*\\\"input\\\"\\s*:\\s*\\[.*"
      }
    ],
    "customMatcher": {
      "name": "state-matcher",
      "parameters": {
        "hasContext": "stub-telegram-wiremock-live-e2e-private-tail-307::{{request.headers.[X-Threlium-Thread-Root]}}"
      }
    }
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "transformers": [
      "response-template"
    ],
    "body": "{{parseJson request.body 'r'}}{\"object\":\"list\",\"model\":\"openai/threlium_e2e_embed\",\"usage\":{\"prompt_tokens\":1,\"total_tokens\":1},\"data\":[{{#each r.input as |txt|}}{{#unless @first}},{{/unless}}{\"object\":\"embedding\",\"index\":{{@index}},\"embedding\":[{{#arrayJoin ',' (range 0 1535) as |d|}}0.0{{/arrayJoin}}]}{{/each}}]}"
  },
  "serveEventListeners": [
    {
      "name": "recordState",
      "parameters": {
        "context": "{{request.headers.[X-Threlium-Thread-Root]}}",
        "list": {
          "addLast": {
            "cs": "{{request.headers.[X-Threlium-Call-Site]}}"
          }
        }
      }
    }
  ]
}
